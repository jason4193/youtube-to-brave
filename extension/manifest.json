{
  "manifest_version": 3,
  "name": "YouTube to Brave Redirector BETA",
  "version": "1.0.0",
  "description": "THIS EXTENSION IS FOR BETA TESTING, Redirects YouTube links to Brave browser.",
  "permissions": ["tabs", "webNavigation", "nativeMessaging", "downloads"],
  "host_permissions": ["*://*.youtube.com/*", "*://*.youtu.be/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "assets/icon.png",
    "default_title": "YouTube to Brave",
    "default_popup": "page/install.html"
  },
  "author": "Jason4193",
  "homepage_url": "https://github.com/jason4193/youtube-to-brave",
  "icons": {
    "128": "assets/icon.png"
  }
}
