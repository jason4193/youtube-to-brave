{
  "manifest_version": 3,
  "name": "YouTube to Brave Redirector BETA",
  "version": "1.0.0",
  "description": "THIS EXTENSION IS FOR BETA TESTING. Automatically opens YouTube links in Brave browser while keeping Chrome for other websites.",
  "permissions": ["tabs", "webNavigation", "nativeMessaging", "downloads"],
  "host_permissions": ["*://*.youtube.com/*", "*://*.youtu.be/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    },
    "default_title": "YouTube to Brave",
    "default_popup": "page/install.html"
  },
  "author": "Jason4193",
  "homepage_url": "https://github.com/jason4193/youtube-to-brave",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
