{
  "manifest_version": 3,
  "name": "YouTube to Brave Redirector",
  "version": "1.0.0",
  "description": "Redirects YouTube links to Brave browser.",
  "permissions": [
    "activeTab",
    "scripting",
    "webNavigation",
    "nativeMessaging",
    "storage",
    "downloads"
  ],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.youtu.be/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_icon": "assets/icon.png",
    "default_title": "YouTube to Brave",
    "default_popup": "page/install.html"
  },
  "author": "Jason4193",
  "homepage_url": "https://github.com/jason4193/youtube-to-brave",
  "icons": {
    "128": "assets/icon.png"
  }
}
